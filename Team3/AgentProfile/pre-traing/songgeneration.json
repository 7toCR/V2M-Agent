  "description_format": "{gender}, {emotion}, {genre}, {timbre}, {instrument}, the bpm is {bpm}.",
  "cross_field_rules": [
    {
      "rule": "emotion_timbre_alignment",
      "description": "sad/melancholic emotions should pair with dark/soft timbre, not bright/rock",
      "conflicts": [
        {"if_emotion": ["sad", "melancholic"], "disallow_timbre": ["bright", "rock"]}
      ]
    },
    {
      "rule": "emotion_genre_alignment",
      "description": "angry emotion should not pair with folk/jazz genre",
      "conflicts": [
        {"if_emotion": ["angry"], "disallow_genre": ["folk", "jazz"]}
      ]
    },
    {
      "rule": "audio_type_genre_coherence",
      "description": "audio_type should broadly align with genre family",
      "conflicts": [
        {"if_audio_type": "Rock", "prefer_genre": ["rock", "hard rock", "classic rock", "pop rock", "rock and roll"]},
        {"if_audio_type": "Jazz", "prefer_genre": ["jazz"]},
        {"if_audio_type": "Folk", "prefer_genre": ["folk", "country"]},
        {"if_audio_type": "Metal", "prefer_genre": ["hard rock", "rock"]},
        {"if_audio_type": "Dance", "prefer_genre": ["electronic", "dance, electronic", "dance, pop", "dance, dancepop, house, pop", "dance, deephouse, electronic", "k-pop"]},
        {"if_audio_type": "R&B", "prefer_genre": ["R&B", "soul"]}
      ]
    },
    {
      "rule": "language_title_lyric_match",
      "description": "Chinese title requires Chinese lyrics; English title requires English lyrics"
    }
  ]
